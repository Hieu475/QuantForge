# QuantForge .gitignore

# Build
build/
cmake-build-*/
.cache/

# In-source CMake/Make artifacts (accidentally generated in source tree)
**/CMakeFiles/
**/CMakeCache.txt
**/cmake_install.cmake
**/Makefile
**/tablegen_compile_commands.yml

# Compiled outputs that can appear in source tree from in-source builds
**/*.a
**/*.o
**/*.o.d
**/*.dwo
**/quantforge-opt

# IDE
.idea/
.vscode/

# Python
__pycache__/
*.pyc
*.egg-info/
dist/
*.pt

# LLVM/MLIR generated
*.inc
*.cpp.inc
*.h.inc

# OS
.DS_Store
Thumbs.db

# Profiling
*.nsys-rep
*.ncu-rep
*.sqlite

#md
nhiem_vu.md

/docs

Research.md

fix.patch
compile_commands.json
